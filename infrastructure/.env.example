# ============================================
# Pulse Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# docker-compose reads from .env automatically.
# ============================================

# ── Supabase ───────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── AI / LLM ──────────────────────────────
GROQ_API_KEY=

# ── Auth ───────────────────────────────────
JWT_SECRET=

# ── Internal Service URLs ─────────────────
# Used by services to communicate with each other
# inside the Docker network (service-name:port).
AUTH_SERVICE_URL=http://auth-service:3001
CANDIDATE_SERVICE_URL=http://candidate-service:3002
PIPELINE_SERVICE_URL=http://pipeline-service:3003
JD_PARSER_URL=http://jd-parser:8000
NOTIFICATION_SERVICE_URL=http://notification-service:3004
COPILOT_SERVICE_URL=http://copilot-service:3005
